{
  "name": "@mmd2pptx/cli",
  "version": "0.1.0",
  "description": "Command-line interface for converting Mermaid SVG diagrams into editable PowerPoint presentations.",
  "type": "module",
  "license": "Apache-2.0",
  "private": true,
  "bin": {
    "mmd2pptx": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm --filter @mmd2pptx/core build && tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@mmd2pptx/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
